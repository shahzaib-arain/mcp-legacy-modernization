datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

enum Role {
  USER
  MANAGER
  ADMIN
}

model User {
  id               String                @id @default(uuid())
  username         String                @unique
  password         String
  name             String
  role             Role                  @default(USER)
  createdAt        DateTime              @default(now())
  
  // Relations
  requests         VerificationRequest[] @relation("UserRequests")
  managerRequests  VerificationRequest[] @relation("ManagerVerifications")
  adminRequests    VerificationRequest[] @relation("AdminVerifications")
}

model CitizenRecord {
  id                Int      @id @default(autoincrement())
  nic               String   @unique
  name              String
  fatherNic         String
  motherName        String
  birthCertificate  String
  residentForm      String
  maritalStatus     String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  isVerified        Boolean  @default(false)
  verifiedByManager String?
  verifiedByAdmin   String?
}

enum RequestStatus {
  PENDING_MANAGER
  PENDING_ADMIN
  APPROVED
  REJECTED
}

model VerificationRequest {
  id               String        @id @default(uuid())
  nic              String?       @unique
  name             String
  fatherNic        String
  motherName       String
  birthCertificate String
  residentForm     String
  maritalStatus    String
  age              Int
  status           RequestStatus @default(PENDING_MANAGER)
  
  // Relations
  userId           String
  user             User          @relation("UserRequests", fields: [userId], references: [id])
  
  managerId        String?
  manager          User?         @relation("ManagerVerifications", fields: [managerId], references: [id])
  managerVerifiedAt DateTime?
  
  adminId          String?
  admin            User?         @relation("AdminVerifications", fields: [adminId], references: [id])
  adminVerifiedAt  DateTime?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}
